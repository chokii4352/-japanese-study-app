    const phrases = LEVEL_PHRASES[idx].length;
    const best = prog.bestScores[idx] || 0;

    const card = document.createElement('div');
    card.className = 'level-card ' + (locked ? 'locked' : 'unlocked') + (cleared ? ' cleared' : '') + (isCurrent ? ' active-level' : '');
    card.innerHTML = `
      <div class="level-card-bg">${m.emoji}</div>
      <div class="level-card-header">
        <div class="level-emoji">${locked ? '🔒' : m.emoji}</div>
