          <div class="level-sub">${m.subtitle}</div>
        </div>
        <div class="level-status ${locked?'status-locked':cleared?'status-cleared':isCurrent?'status-current':'status-unlocked'}">
          ${locked ? '잠김' : cleared ? '✓ 클리어' : isCurrent ? '현재' : '도전 가능'}
        </div>
      </div>
      ${!locked ? `
      <div class="level-details">
        <div class="level-detail-item">단어 <span>${words}개</span></div>
        <div class="level-detail-item">회화 <span>${phrases}개</span></div>
        <div class="level-detail-item">최고점 <span>${best}/10</span></div>
      </div>
      <div class="level-prog-row">
        <div class="level-prog-bar">
          <div class="level-prog-fill" style="width:${best/10*100}%;background:${m.color}"></div>
        </div>
        <div class="level-prog-text">${best}/10점</div>
      </div>
      ${!cleared ? `<button class="btn-start-level" onclick="goStudyLevel(${lv})" style="background:${m.grad};color:#3d2c3e">
        ${isCurrent ? '지금 공부하기 →' : '이 단계 공부하기 →'}
      </button>` : ''}
      ` : ''}
    `;
    grid.appendChild(card);
  });
}

function goStudyLevel(lv) {
  studyLevel = lv;
  updateHeader();
  // Switch to quiz tab
  const quizBtn = document.querySelectorAll('.nav-btn')[3];
  showSection('quiz', quizBtn);
}

// ═══════════════════════════════════════════════════
// 1. KANA
// ═══════════════════════════════════════════════════
let currentKana = 'hiragana';
let allRevealed = false;

function renderKanaSection() {
  makeLevelBar('kanaLevelBar', () => renderKanaSection());
  updateHeader();
  renderKanaGrid();
}

function switchKana(type, btn) {
  currentKana = type;
  document.querySelectorAll('.kana-tab').forEach(b => b.classList.remove('active'));
  btn.classList.add('active');
  renderKanaGrid();
}

function renderKanaGrid() {
  allRevealed = false;
  const container = document.getElementById('kanaContent');
  container.innerHTML = '';
  const kd = KANA_GROUPS[studyLevel-1];
  const kanaArr = currentKana === 'hiragana' ? kd.hira : kd.kata;
  
  const label = document.createElement('div');
  label.className = 'kana-group-label';
  label.textContent = kd.label;
  container.appendChild(label);

  const grid = document.createElement('div');
  grid.className = 'kana-grid';
  kanaArr.forEach(k => {
    const card = document.createElement('div');
    card.className = 'kana-card';
    card.innerHTML = `<span class="kana-char">${k.c}</span><span class="kana-roman">${k.r}</span>`;
    card.onclick = () => card.classList.toggle('revealed');
    grid.appendChild(card);
  });
  container.appendChild(grid);
}

function toggleRevealAll() {
  allRevealed = !allRevealed;
  const cards = document.querySelectorAll('.kana-card');
  cards.forEach(c => allRevealed ? c.classList.add('revealed') : c.classList.remove('revealed'));
}

// ═══════════════════════════════════════════════════
// 2. FLASHCARD
// ═══════════════════════════════════════════════════
let fcWords = [], fcIndex = 0, fcAll = false;

function renderFlashcardSection() {
  fcAll = false;
  makeLevelBar('fcLevelBar', () => { fcAll = false; renderFlashcardSection(); });
  updateHeader();
  fcWords = [...LEVEL_WORDS[studyLevel-1]];
  fcIndex = 0;
  showFlashcard();
}

function showFlashcard() {
  if (fcWords.length === 0) return;
  const w = fcWords[fcIndex];
  document.getElementById('fcLevelTag').textContent = studyLevel + '단계';
  document.getElementById('fcLevelTagBack').textContent = studyLevel + '단계';
  document.getElementById('fcJp').textContent = w.jp;
  document.getElementById('fcReading').textContent = w.r;
  document.getElementById('fcMeaning').textContent = w.kr;
  document.getElementById('fcExample').innerHTML = w.ex.replace(/\n/g, '<br>');
  document.getElementById('fcCounter').textContent = `${fcIndex+1} / ${fcWords.length}`;
  document.getElementById('flashcardInner').classList.remove('flipped');
}

function flipCard() {
  document.getElementById('flashcardInner').classList.toggle('flipped');
}

function prevCard() {
  fcIndex = (fcIndex - 1 + fcWords.length) % fcWords.length;
  showFlashcard();
}

function nextCard() {
  fcIndex = (fcIndex + 1) % fcWords.length;
  showFlashcard();
}

function shuffleFlashcards() {
  shuffleArray(fcWords);
  fcIndex = 0;
  showFlashcard();
  showToast('🔀 카드를 섞었어요!');
}

function toggleAllLevels() {
  fcAll = !fcAll;
  if (fcAll) {
    fcWords = [];
    for (let i = 0; i < prog.unlockedLevel; i++) fcWords = fcWords.concat(LEVEL_WORDS[i]);
    shuffleArray(fcWords);
    showToast('🌟 모든 단계 단어를 보여줘요!');
  } else {
    fcWords = [...LEVEL_WORDS[studyLevel-1]];
    showToast(`${LEVEL_META[studyLevel-1].emoji} ${studyLevel}단계 단어만 보여줘요!`);
  }
  fcIndex = 0;
  showFlashcard();
}

function shuffleArray(arr) {
  for (let i = arr.length - 1; i > 0; i--) {
    const j = Math.floor(Math.random() * (i + 1));
    [arr[i], arr[j]] = [arr[j], arr[i]];
  }
  return arr;
}

// ═══════════════════════════════════════════════════
// 3. QUIZ
// ═══════════════════════════════════════════════════
let quizStarted = false, quizQuestions = [], quizCurrent = 0, quizScore = 0, quizAnswered = false;
const QUIZ_TOTAL = 10, QUIZ_PASS = 7;

function startQuiz() {
  quizStarted = true;
  quizScore = 0; quizCurrent = 0; quizAnswered = false;
  makeLevelBar('quizLevelBar', () => { quizStarted = false; startQuiz(); });
  updateHeader();

  const words = LEVEL_WORDS[studyLevel-1];
  const kanaData = KANA_GROUPS[studyLevel-1].hira;
  const pool = [];

  words.forEach(w => pool.push({
    type:'word', q:w.jp, sub:w.r, label:'다음 일본어의 뜻은?',
    answer:w.kr, pool:words.map(x=>x.kr)
  }));
  kanaData.slice(0, Math.min(10, kanaData.length)).forEach(k => pool.push({
    type:'kana', q:k.c, sub:'', label:'이 가나의 읽는 법은?',
    answer:k.r, pool:kanaData.map(x=>x.r)
  }));

  shuffleArray(pool);
  quizQuestions = pool.slice(0, QUIZ_TOTAL);

  const passInd = document.getElementById('quizPassInd');
  passInd.textContent = `${QUIZ_PASS}점 이상 → ${studyLevel}단계 클리어!`;
  passInd.className = 'quiz-pass-indicator' + (!prog.cleared[studyLevel-1] ? ' reachable' : '');

  document.getElementById('quizGame').style.display = 'block';
  document.getElementById('quizResult').style.display = 'none';
  renderQuestion();
}

function renderQuestion() {
  const q = quizQuestions[quizCurrent];
  quizAnswered = false;
  document.getElementById('quizScore').textContent = `점수: ${quizScore}`;
  const pct = quizCurrent / QUIZ_TOTAL;
  document.getElementById('quizProgressFill').style.width = `${pct*100}%`;
  document.getElementById('quizLabel').textContent = q.label;
  document.getElementById('quizQuestion').textContent = q.q;
  document.getElementById('quizQuestionSub').textContent = q.sub;
  document.getElementById('quizFeedback').textContent = '';
  document.getElementById('quizFeedback').className = 'quiz-feedback';
  document.getElementById('btnNextQ').disabled = true;
  document.getElementById('btnNextQ').textContent = '다음 문제 →';

  const wrongPool = [...new Set(q.pool.filter(x => x !== q.answer))];
  shuffleArray(wrongPool);
  const opts = shuffleArray([q.answer, ...wrongPool.slice(0,3)]);

  const container = document.getElementById('quizOptions');
  container.innerHTML = '';
  opts.forEach(opt => {
    const btn = document.createElement('button');
    btn.className = 'quiz-opt';
    btn.textContent = opt;
    btn.onclick = () => checkAnswer(opt, q.answer, btn);
    container.appendChild(btn);
  });
}

function checkAnswer(selected, correct, btn) {
  if (quizAnswered) return;
  quizAnswered = true;
  document.querySelectorAll('.quiz-opt').forEach(b => {
    b.disabled = true;
    if (b.textContent === correct) b.classList.add('correct');
  });
  const fb = document.getElementById('quizFeedback');
  if (selected === correct) {
    quizScore++;
    btn.classList.add('correct');
    fb.textContent = '🎉 정답이에요!';
    fb.className = 'quiz-feedback correct';
  } else {
    btn.classList.add('wrong');
    fb.textContent = `❌ 오답! 정답은 "${correct}" 이에요.`;
    fb.className = 'quiz-feedback wrong';
  }
  document.getElementById('quizScore').textContent = `점수: ${quizScore}`;
  document.getElementById('btnNextQ').disabled = false;
  if (quizCurrent === QUIZ_TOTAL-1) document.getElementById('btnNextQ').textContent = '결과 보기 🌸';
}

function nextQuestion() {
  quizCurrent++;
  if (quizCurrent >= QUIZ_TOTAL) showQuizResult();
  else renderQuestion();
}

function showQuizResult() {
  document.getElementById('quizProgressFill').style.width = '100%';
  document.getElementById('quizGame').style.display = 'none';
  const resultDiv = document.getElementById('quizResult');
  resultDiv.style.display = 'block';

  const passed = quizScore >= QUIZ_PASS;
  const prevBest = prog.bestScores[studyLevel-1] || 0;
  if (quizScore > prevBest) prog.bestScores[studyLevel-1] = quizScore;

  let levelCleared = false;
  if (passed && !prog.cleared[studyLevel-1]) {
    prog.cleared[studyLevel-1] = true;
    if (studyLevel < 5 && prog.unlockedLevel < studyLevel+1) {
      prog.unlockedLevel = studyLevel+1;
    }
    levelCleared = true;
  }
  saveProgress(prog);
  updateHeader();
  renderLevelMap();

  const pct = quizScore / QUIZ_TOTAL;
  let emoji, msg;
  if (pct === 1)      { emoji='🏆'; msg='완벽해요! 素晴らしい！'; }
  else if (pct>=0.8)  { emoji='🌸'; msg='아주 잘했어요!'; }
  else if (pct>=0.6)  { emoji='😊'; msg='잘했어요! 조금만 더 연습해봐요.'; }
  else if (pct>=0.4)  { emoji='💪'; msg='아직 부족해요. 다시 도전해봐요!'; }
  else                { emoji='📚'; msg='がんばって！ 더 공부해봐요!'; }

  let clearBanner = '';
  if (levelCleared) {
    const next = LEVEL_META[studyLevel];
    clearBanner = `<div class="level-clear-banner">🎊 ${studyLevel}단계 클리어! ${next ? next.emoji+' '+(studyLevel+1)+'단계 '+next.name+'이 열렸어요!' : '모든 단계를 완료했어요! 축하해요!'}</div>`;
  } else if (!passed) {
    clearBanner = `<div style="background:#fff0f5;border:2px solid var(--pink);border-radius:12px;padding:10px 14px;margin:10px 0;font-size:13px;color:var(--pink-dark)">
      💡 ${QUIZ_PASS}점 이상이면 다음 단계가 열려요. 조금만 더 연습해봐요!
    </div>`;
  }

  const nextLvBtn = (levelCleared && studyLevel < 5)
    ? `<button class="btn-next-level" onclick="goStudyLevel(${studyLevel+1})">다음 단계 도전 ${LEVEL_META[studyLevel].emoji}</button>`
    : '';

  resultDiv.innerHTML = `
    <div class="quiz-result">
      <div class="emoji">${emoji}</div>
      <h3>퀴즈 완료! ${LEVEL_META[studyLevel-1].emoji} ${studyLevel}단계</h3>
      <div class="final-score">${quizScore} / ${QUIZ_TOTAL}</div>
      <p>${msg}</p>
      ${clearBanner}
      <div class="quiz-result-btns">
        <button class="btn-restart" onclick="startQuiz()">다시 도전 🌸</button>
        ${nextLvBtn}
      </div>
    </div>
  `;
}

// ═══════════════════════════════════════════════════
// 4. CONVERSATION
// ═══════════════════════════════════════════════════
let currentConvLv = 1;

function renderConvSection() {
  currentConvLv = studyLevel;
  makeLevelBar('convLevelBar', () => { currentConvLv = studyLevel; renderConvSection(); });
  renderConvLevelTabs();
  renderPhrases();
  updateHeader();
}

function renderConvLevelTabs() {
  const tabs = document.getElementById('convCatTabs');
  tabs.innerHTML = '';
  for (let i = 1; i <= prog.unlockedLevel; i++) {
    const m = LEVEL_META[i-1];
    const btn = document.createElement('button');
    btn.className = 'conv-cat-btn' + (i === currentConvLv ? ' active' : '');
    btn.textContent = `${m.emoji} ${i}단계`;
    btn.onclick = () => { currentConvLv = i; renderConvLevelTabs(); renderPhrases(); };
    tabs.appendChild(btn);
  }
}

function renderPhrases() {
  const list = document.getElementById('phraseList');
  list.innerHTML = '';
  const phrases = LEVEL_PHRASES[currentConvLv-1];
  phrases.forEach(p => {
    const card = document.createElement('div');
    card.className = 'phrase-card';
    card.innerHTML = `
      <span class="speak-icon">🔊</span>
      <div class="phrase-lv-tag">${LEVEL_META[currentConvLv-1].emoji} ${currentConvLv}단계</div>
      <div class="phrase-jp">${p.jp}</div>
      <div class="phrase-reading">${p.r}</div>
      <div class="phrase-kr">${p.kr}</div>
      ${p.note ? `<div class="phrase-note">💡 ${p.note}</div>` : ''}
    `;
    card.onclick = () => speak(p.jp);
    list.appendChild(card);
  });
}

function speak(text) {
  if ('speechSynthesis' in window) {
    const utt = new SpeechSynthesisUtterance(text);
    utt.lang = 'ja-JP'; utt.rate = 0.85;
    window.speechSynthesis.cancel();
    window.speechSynthesis.speak(utt);
  }
}

// ── TOAST ──
function showToast(msg) {
  const t = document.getElementById('toast');
  t.textContent = msg;
  t.classList.add('show');
  setTimeout(() => t.classList.remove('show'), 2400);
}

// ── INIT ──
updateHeader();
renderLevelMap();
</script>


