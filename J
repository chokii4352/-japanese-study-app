// ═══════════════════════════════════════════════════
// PROGRESS STATE (localStorage)
// ═══════════════════════════════════════════════════
function loadProgress() {
  try { return JSON.parse(localStorage.getItem('jpProgress')) || {}; } catch(e) { return {}; }
}
function saveProgress(p) { localStorage.setItem('jpProgress', JSON.stringify(p)); }

let prog = loadProgress();
if (!prog.unlockedLevel) prog.unlockedLevel = 1;
if (!prog.bestScores) prog.bestScores = [0,0,0,0,0];
if (!prog.cleared) prog.cleared = [false,false,false,false,false];
saveProgress(prog);

// current study level (can be any unlocked level)
let studyLevel = prog.unlockedLevel; // 1-based

// ═══════════════════════════════════════════════════
// NAVIGATION
// ═══════════════════════════════════════════════════
function showSection(id, btn) {
  document.querySelectorAll('.section').forEach(s => s.classList.remove('active'));
  document.querySelectorAll('.nav-btn').forEach(b => b.classList.remove('active'));
  document.getElementById(id).classList.add('active');
  btn.classList.add('active');
  if (id === 'quiz') { quizStarted = false; startQuiz(); }
  if (id === 'kana') renderKanaSection();
  if (id === 'flashcard') renderFlashcardSection();
  if (id === 'conv') renderConvSection();
}

// ── Study Level Selector Bar (used in multiple sections)
function makeLevelBar(containerId, onChange) {
  const bar = document.getElementById(containerId);
  bar.innerHTML = '<span class="study-level-label">공부 단계:</span>';
  for (let i = 1; i <= 5; i++) {
    const m = LEVEL_META[i-1];
    const btn = document.createElement('button');
    btn.className = 'slv-btn' + (i > prog.unlockedLevel ? ' locked' : ' unlocked') + (i === studyLevel ? ' active-lv' : '');
    btn.textContent = (i > prog.unlockedLevel ? '🔒' : m.emoji) + ' ' + i + '단계';
    btn.title = i > prog.unlockedLevel ? '이전 단계를 클리어해야 열려요' : m.name;
    btn.onclick = () => { if (i > prog.unlockedLevel) { showToast('🔒 이전 단계를 클리어해야 열 수 있어요!'); return; } studyLevel = i; onChange(); };
    bar.appendChild(btn);
  }
}

// ── Update header
function updateHeader() {
  const m = LEVEL_META[studyLevel-1];
  document.getElementById('headerLvEmoji').textContent = m.emoji;
  document.getElementById('headerLvText').textContent = `${studyLevel}단계 · ${m.name}`;
  const cleared = prog.cleared.filter(Boolean).length;
  document.getElementById('headerProgressFill').style.width = (cleared / 5 * 100) + '%';
}

